# Innovarib Brain OS - Docker Compose environment

# PostgreSQL
POSTGRES_DB=innovarib
POSTGRES_USER=innovarib
POSTGRES_PASSWORD=innovarib_dev_password
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_DEFAULT_USER=innovarib
RABBITMQ_DEFAULT_PASS=innovarib_dev_password
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_dev_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=innovarib-brain-os

# Backend Spring Boot
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=dev
JWT_SECRET=change-me-in-local-development-only

# Frontend Angular
FRONTEND_PORT=4200

# Optional Nginx reverse proxy
NGINX_PORT=80
